{
  "name": "ai_coding_ws Codespace",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "remoteUser": "node",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "React dev server",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },
  "containerEnv": {
    "CHOKIDAR_USEPOLLING": "true"
  },
  "postCreateCommand": "sudo apt-get update -y && sudo apt-get install -y jq && (npm ci || npm install) && bash scripts/seed-cline-settings.sh && bash scripts/set-title.sh",
  "postAttachCommand": "gh codespace ports visibility 3000:public -c $CODESPACE_NAME >/dev/null 2>&1 || true; bash scripts/welcome.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "saoudrizwan.claude-dev"
      ],
      "settings": {
        "files.autoSave": "onFocusChange",
        "workbench.startupEditor": "readme",
        "chat.disableAIFeatures": true,
        "chat.commandCenter.enabled": false,
        "github.copilot.enable": { "*": false }
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  }
}
