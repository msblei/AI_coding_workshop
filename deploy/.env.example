# Copy to deploy/.env and fill in. Never commit the real .env.

# The subdomain base you control. Phase 0 will serve test.<this> and
# test-app.<this>. Example: ai-coding-workshop.example.com
DOMAIN=ai-coding-workshop.example.com

# Email for Let's Encrypt expiry notices.
ACME_EMAIL=you@example.com

# Password to log in to the test IDE.
TEST_PASSWORD=change-me

# Your LiteLLM proxy base URL + model. Leave LITELLM_BASE_URL blank in Phase 0
# if you just want to test that the IDE loads; set it to test Cline end-to-end.
LITELLM_BASE_URL=
MODEL=claude-opus-4-7
